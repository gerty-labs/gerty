FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /sage-agent ./cmd/agent

FROM alpine:3.19
RUN apk --no-cache add ca-certificates
COPY --from=builder /sage-agent /sage-agent
USER 65534:65534
ENTRYPOINT ["/sage-agent"]
